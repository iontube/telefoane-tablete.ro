  { title: "Samsung Galaxy A35 5G", id: "samsung-galaxy-a35-5g" },
  { title: "OnePlus Nord 4", id: "oneplus-nord-4" },
  { title: "Realme 12 Pro+", id: "realme-12-pro" },
  { title: "Motorola Moto G84 5G", id: "motorola-moto-g84-5g" },
