};

const breadcrumbs = [
  { name: "Acasa", url: "/" },
  { name: "Telefoane", url: "/telefoane/" },
  { name: "Top telefoane sub 500 lei", url: "/top-telefoane-sub-500-lei/" }
];

const faq = [
  { question: "Care este cel mai bun telefon sub 500 lei in 2026?", answer: "In 2026, Xiaomi Redmi 12C este considerat unul dintre cele mai bune telefoane sub 500 lei datorita procesorului Helio G85, 4GB RAM, camerei de 50MP si bateriei de 5000 mAh." },
  { question: "Ce autonomie am de la un telefon sub 500 lei?", answer: "Telefoanele din aceasta categorie, cu baterii de 4500-5000 mAh, ofera de obicei o zi intreaga de utilizare moderata, ajungand chiar la doua zile pentru utilizatori ocazionali." },
  { question: "Pot juca jocuri pe un telefon sub 500 lei?", answer: "Da, dar cu limitari. Modelele cu minim 3GB RAM si procesoare octa-core decente, precum Xiaomi Redmi 12C, pot rula jocuri mai putin solicitante. Nu te astepta la performante de top in jocuri complexe." },
  { question: "Sunt bune camerele foto la telefoanele sub 500 lei?", answer: "Camerele sunt in general modeste. Modelele cu camere de 13MP sau 50MP pot face poze bune in lumina naturala, dar performanta scade semnificativ in conditii de lumina slaba. Nu sunt potrivite pentru fotografia profesionala." },
  { question: "Unde gasesc cele mai bune oferte pentru telefoane sub 500 lei?", answer: "Cele mai bune oferte se gasesc in magazinele online mari din Romania, precum eMAG, Altex, Flanco sau PC Garage, unde poti compara preturile si verifica stocurile disponibile." }
];

const toc = [
  { title: "Allview A50 Lite", id: "allview-a50-lite" },
  { title: "Allview P9 Lite 2017 (reconditionat)", id: "allview-p9-lite-2017-reconditionat" },
  { title: "Nokia C21 Plus", id: "nokia-c21-plus" },
  { title: "Samsung Galaxy A04e", id: "samsung-galaxy-a04e" },
  { title: "Xiaomi Redmi 12C", id: "xiaomi-redmi-12c" },
  { title: "Motorola Moto E13", id: "motorola-moto-e13" },
  { title: "Comparatie", id: "comparatie" },
  { title: "Cum alegi telefonul potrivit sub 500 lei in 2026?", id: "sfaturi" },
  { title: "Intrebari Frecvente", id: "faq" }
];

const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
