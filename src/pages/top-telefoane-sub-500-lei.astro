---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Top telefoane sub 500 lei",
  excerpt: "Daca cauti top telefoane sub 500 lei, probabil vrei un dispozitiv functional pentru sarcini de baza, fara costuri mari. In 2026, piata ofera cateva optiuni decente in acest segment, focusul fiind pe autonomie si functionalitate esentiala.",
  image: "/images/articles/top-telefoane-sub-500-lei.webp",
  category: "Telefoane",
  categorySlug: "telefoane",
  date: "2026-03-12T08:40:36.174Z",
  modifiedDate: "2026-03-12T08:40:36.175Z",
  author: "Andrei Ionescu",
  authorRole: "Iubitor de telefoane, impatimit in tehnologie",
