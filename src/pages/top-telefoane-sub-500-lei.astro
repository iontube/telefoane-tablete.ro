        <li><a href="/">Acasa</a></li>
        <li>Telefoane</li>
        <li><span>Top telefoane sub 500 lei</span></li>
      </ol>
    </nav>

    Telefoane
    <h1 class="article-page-title">Top telefoane sub 500 lei</h1>

    <div class="article-page-meta">
      <span>Andrei Ionescu</span>
      <span>&middot;</span>
      <span>Publicat: 12 martie 2026</span>
      <span>&middot;</span>
      <span>Actualizat: 12 martie 2026</span>
    </div>

