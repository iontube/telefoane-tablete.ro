              </div>
              <div class="product-review__spec">
                <strong>Ram</strong>3 GB
              </div>
              <div class="product-review__spec">
                <strong>Stocare</strong>16 GB
              </div>
              <div class="product-review__spec">
                <strong>Baterie</strong>3000 mAh
              </div>
              <div class="product-review__spec">
                <strong>Camera</strong>13MP principal + 5MP frontal
